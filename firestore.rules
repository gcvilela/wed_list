// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: gifts
// Fields:
//   - title: string (required)
//   - description: string (optional)
//   - imageUrl: string (required, URL)
//   - price: number (required)
//   - collected: number (required)
//   - category: string (optional)
//
// Collection: messages
// Fields:
//   - guestName: string (required)
//   - message: string (required)
//   - giftId: string (required)
//   - amount: number (required)
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              request.auth.token.email == "ronaldvilela12@gmail.com");
    }

    function isValidGift(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.collected is number && data.collected >= 0 &&
             data.imageUrl is string && data.imageUrl.matches("^https?://.*");
    }

    function isValidMessage(data) {
      return data.guestName is string && data.guestName.size() > 0 && data.guestName.size() < 50 &&
             data.message is string && data.message.size() < 1000 &&
             data.amount is number && data.amount > 0;
    }

    // Rules
    match /gifts/{giftId} {
      // ROUND 16: Firebase Query DoS Protection
      allow read: if request.query.limit <= 100;
      
      // ROUND 19, 101-105: Strict Typing and Mass Assignment Protection
      allow update: if isAdmin() && 
                    request.resource.data.keys().hasOnly(['title', 'description', 'imageUrl', 'price', 'collected', 'category', 'status']) &&
                    request.resource.data.price is int &&
                    request.resource.data.collected is int &&
                    request.resource.data.status in ['active', 'completed', 'draft'];
      
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      // Only admins can read all messages (to see who gave what)
      allow read: if isAdmin() && request.query.limit <= 100;
      
      // ROUND 101-105: Strict Typing for messages
      allow write: if isAdmin() &&
                   request.resource.data.keys().hasOnly(['giftId', 'guestName', 'message', 'timestamp', 'amount']) &&
                   request.resource.data.amount is int &&
                   request.resource.data.guestName is string &&
                   request.resource.data.message is string;
    }

    // ROUND 20 & 45: Append-only Audit Logs (Non-deletable, Non-updatable)
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      // Ensure logs must have a unique ID and certain required fields
      allow create: if isAdmin() && 
                    request.resource.data.keys().hasAll(['event', 'timestamp', 'paymentId']) &&
                    request.resource.data.timestamp == request.time;
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if request.auth.uid == userId || isAdmin();
      
      // CRITICAL SECURITY (Red Team Patch): 
      // Users CANNOT write or update their own 'role' or 'isAdmin' fields.
      // This prevents a user from making themselves an admin via the console.
      allow create: if request.auth.uid == userId && 
                     !request.resource.data.keys().hasAny(['role', 'isAdmin']);
      
      allow update: if (request.auth.uid == userId && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin'])) ||
                     isAdmin();
    }
  }
}
